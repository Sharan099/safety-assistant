# Required: Groq API key for LLM responses
GROQ_API_KEY=your_groq_api_key

# LangSmith observability (query, docs, prompt, response, latency)
LANGSMITH_API_KEY=your_langsmith_api_key
LANGSMITH_PROJECT=autosafety-rag
LANGSMITH_TRACING=false

# Hybrid + rerank chain
ENABLE_RERANKER=true
RERANKER_MODEL=BAAI/bge-reranker-base
# Preload embedding/reranker at startup (slower boot, faster first chat)
PRELOAD_ML_MODELS=false
# Semantic search on (BM25 + semantic -> RRF -> rerank). Set true for BM25-only.
DISABLE_SEMANTIC=false

# Windows torch fix: avoids OpenMP DLL access-violation (exit 0xC0000005)
KMP_DUPLICATE_LIB_OK=TRUE
OMP_NUM_THREADS=1

# Optional hybrid retrieval tuning
SEMANTIC_WEIGHT=0.6
BM25_WEIGHT=0.4
TOP_K_AFTER_RERANK=5

# Ingestion: supplement OCR markdown with PyMuPDF text layer
PYMUPDF_SUPPLEMENT=true

# OCR engine for scanned PDFs: paddle (low-memory) | docling | pymupdf
OCR_ENGINE=paddle
# OCR backend: auto = try PaddleOCR, fall back to PP-OCR ONNX (rapidocr) on Windows
OCR_BACKEND=rapidocr
OCR_DPI=150
OCR_BATCH_PAGES=4
OCR_LANG=en
OCR_SKIP_TEXT_PAGES=true
OCR_MIN_TEXT_CHARS=200
# Set OCR_FORCE_ALL=true for pure scans with no/garbage text layer
OCR_FORCE_ALL=false

# Embedding batch size (lower if CPU runs out of memory)
EMBEDDING_BATCH=4
