# ── LLM ──────────────────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MODEL_FAST=llama-3.1-8b-instant
GROQ_MODEL_ANALYSIS=claude-sonnet-4-20250514

# Hard metadata pre-filter (frontal≠side, legal≠rating)
ENABLE_HARD_METADATA_FILTER=true
CORPUS_VERSION=4

# ── Hybrid retrieval stack (v3.2) ─────────────────────────────────────
# Dense leg: Nomic (768-dim, task prefixes). Sparse: BM25. Fusion: RRF.
EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5
EMBEDDING_TRUST_REMOTE_CODE=true
EMBEDDING_QUERY_PREFIX=search_query: 
EMBEDDING_DOC_PREFIX=search_document: 
EMBEDDING_BATCH=2
EMBED_SAVE_EVERY=200

# Reranker — model + kind MUST match (see deploy/hf-space/README.md)
# CPU / HF Space (recommended):
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_KIND=crossencoder
# GPU / local Jina alternative:
# RERANKER_MODEL=jinaai/jina-reranker-v3
# RERANKER_KIND=jina
ENABLE_RERANKER=true
# Pin HF revisions to silence remote-code re-download warnings (optional git ref only)
# EMBEDDING_REVISION=main
# RERANKER_REVISION=main
# NOT boolean — use EMBEDDING_TRUST_REMOTE_CODE=true for Nomic remote code

# RRF / hybrid weights
RRF_K=60
SEMANTIC_WEIGHT=0.6
BM25_WEIGHT=0.4
TOP_K_RETRIEVE=12
TOP_K_AFTER_RERANK=5

# RAGAS judge (evaluation only — higher than answer LLM)
RAGAS_JUDGE_MAX_TOKENS=4096

# Admin feedback dashboard (/dashboard on frontend → GET /feedback/dashboard)
FEEDBACK_DASHBOARD_KEY=change-me-to-a-long-random-secret

HF_HOME=/app/.cache/huggingface

# ── Gateway (optional) ───────────────────────────────────────────────
ENABLE_GATEWAY=false
# Primary Groq tier — must be 70B, NOT 8B (misconfig causes 100% fallback bugs)
GROQ_TIER_MODEL=llama-3.3-70b-versatile
GROQ_TIER_MODEL_POWER=llama-3.3-70b-versatile
GROQ_TIER_MODEL_FAST=llama-3.1-8b-instant
ANTHROPIC_API_KEY=
CLAUDE_HAIKU_MODEL=claude-haiku-4-5
CLAUDE_SONNET_MODEL=claude-sonnet-4-5
GATEWAY_SHADOW_MODE=false
GATEWAY_CANARY_PCT=100

# ── Production (Railway / Hugging Face Spaces) ───────────────────────
# HF Space backend: https://sharan099-passive-safety-assistant.hf.space
# Vercel frontend:  https://safety-assistant-tan.vercel.app
CORS_ORIGINS=https://safety-assistant-tan.vercel.app,http://localhost:3000
APP_DB_PATH=/app/var/app.db
ENABLE_PROMETHEUS_METRICS=false
RUN_SELFTEST_ON_STARTUP=false

# ── LangSmith (optional) ─────────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=psa-ai
