# ── LLM ──────────────────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── Retrieval models ───────────────────────────────────────────────────
EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
ENABLE_RERANKER=true
HF_HOME=/app/.cache/huggingface

# ── Gateway (optional) ───────────────────────────────────────────────
ENABLE_GATEWAY=false

# ── Production (Railway) ─────────────────────────────────────────────
# Comma-separated origins — add your Vercel URL, e.g. https://psa-ai.vercel.app
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000
# Persist SQLite on a Railway volume mounted at /app/var
APP_DB_PATH=/app/var/app.db
# Railway: leave false (no Prometheus scraper). Local docker-compose sets true.
ENABLE_PROMETHEUS_METRICS=false
# Skip background LLM self-test on cold start to speed Railway healthchecks
RUN_SELFTEST_ON_STARTUP=false

# ── LangSmith (optional) ─────────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=psa-ai
