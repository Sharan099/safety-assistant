# Required: Groq API key for LLM responses
GROQ_API_KEY=your_groq_api_key

# LangSmith observability (query, docs, prompt, response, latency)
LANGSMITH_API_KEY=your_langsmith_api_key
LANGSMITH_PROJECT=autosafety-rag
LANGSMITH_TRACING=false

# Hybrid + rerank chain
ENABLE_RERANKER=true
RERANKER_MODEL=BAAI/bge-reranker-base
# Preload embedding/reranker at startup (slower boot, faster first chat)
PRELOAD_ML_MODELS=false
# Semantic search on (BM25 + semantic -> RRF -> rerank). Set true for BM25-only.
DISABLE_SEMANTIC=false

# Windows torch fix: avoids OpenMP DLL access-violation (exit 0xC0000005)
KMP_DUPLICATE_LIB_OK=TRUE
OMP_NUM_THREADS=1

# Optional hybrid retrieval tuning
SEMANTIC_WEIGHT=0.6
BM25_WEIGHT=0.4
TOP_K_AFTER_RERANK=5

# Advanced retrieval: expansion -> multi-query -> hybrid -> metadata -> parent-child -> rerank
ENABLE_QUERY_EXPANSION=true
ENABLE_MULTI_QUERY=true
MULTI_QUERY_COUNT=3
ENABLE_METADATA_FILTER=true
METADATA_BOOST=0.5
ENABLE_PARENT_CHILD=true
ENABLE_LLM_MULTI_QUERY=false

# Grounding & citations (v2.1): abstain when retrieval confidence is low
ENABLE_GROUNDING_GATE=true
GROUNDING_MIN_SEMANTIC=0.45
GROUNDING_MIN_RERANK_PROB=0.5
REQUIRE_CITATIONS=true

# Feedback / users / readiness (v2.2)
# SQLite DB for users, sessions, messages, and feedback (testing phase)
APP_DB_PATH=output/app.db
# Run a one-time end-to-end self-test query at startup (frontend gates on /ready)
RUN_SELFTEST_ON_STARTUP=true
# Skip the LLM call during the self-test (retrieval-only readiness)
READY_SKIP_LLM=false

# Security hardening (set real values before cloud deploy)
# Comma-separated allowed browser origins. Do NOT use "*" with credentials.
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
# Basic in-process abuse speed-bump (enforce real limits at the gateway too)
RATE_LIMIT_ENABLED=true
# Send HSTS header (only enable when served over HTTPS)
ENABLE_HSTS=false

# Ingestion: supplement OCR markdown with PyMuPDF text layer
PYMUPDF_SUPPLEMENT=true

# OCR engine for scanned PDFs: paddle (low-memory) | docling | pymupdf
OCR_ENGINE=paddle
# OCR backend: auto = try PaddleOCR, fall back to PP-OCR ONNX (rapidocr) on Windows
OCR_BACKEND=rapidocr
OCR_DPI=150
OCR_BATCH_PAGES=4
OCR_LANG=en
OCR_SKIP_TEXT_PAGES=true
OCR_MIN_TEXT_CHARS=200
# Set OCR_FORCE_ALL=true for pure scans with no/garbage text layer
OCR_FORCE_ALL=false

# Embedding batch size (lower if CPU runs out of memory)
EMBEDDING_BATCH=4
