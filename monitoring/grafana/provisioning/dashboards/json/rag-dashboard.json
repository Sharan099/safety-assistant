{
  "title": "AutoSafety RAG — Operations",
  "uid": "autosafety-rag",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "type": "timeseries",
      "title": "Request Latency (p95)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(rag_request_duration_seconds_bucket[5m])) by (le, endpoint))",
          "legendFormat": "{{endpoint}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "LLM Latency",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(rag_llm_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Estimated Cost (USD total)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "targets": [
        { "expr": "rag_estimated_cost_usd_total" }
      ]
    },
    {
      "type": "stat",
      "title": "Prompt Tokens",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "targets": [{ "expr": "rag_tokens_prompt_total" }]
    },
    {
      "type": "stat",
      "title": "Completion Tokens",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "targets": [{ "expr": "rag_tokens_completion_total" }]
    },
    {
      "type": "stat",
      "title": "Error Rate",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(rag_errors_total[5m]))",
          "legendFormat": "errors/s"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Guardrail Blocks",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "sum(rate(rag_guardrail_blocks_total[5m])) by (reason)",
          "legendFormat": "{{reason}}"
        }
      ]
    },
    {
      "type": "gauge",
      "title": "Active Requests",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [{ "expr": "rag_active_requests" }]
    }
  ]
}
